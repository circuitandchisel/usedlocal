# --- Required ---

# Funding destination URL for ATXP payments
FUNDING_DESTINATION_ATXP=https://accounts.atxp.ai/?connection_token=your_connection_token_here

# --- Optional: pricing ---
# Charge per search call (in USD). Set to 0 to disable charging (useful for tests).
# SEARCH_COST=0.02

# --- Optional: source toggles ---
# Enabled sources, comma-separated. Defaults to "craigslist,kijiji".
# Facebook Marketplace requires authentication and is disabled by default.
# ENABLED_SOURCES=craigslist,kijiji

# --- Optional: HTTP behaviour ---
# Per-source timeout (ms). Default 15000.
# SOURCE_TIMEOUT_MS=15000
# Max listings to return per source before deduplication. Default 50.
# MAX_RESULTS_PER_SOURCE=50
# Custom User-Agent for outbound scrapes.
# USER_AGENT=usedlocal/0.1 (+https://github.com/circuitandchisel/usedlocal)

# --- Optional: Facebook Marketplace ---
# If set, the Facebook source will use this Apify actor token to query Marketplace.
# (See README for setup; without this, the FB source is a no-op stub.)
# FACEBOOK_APIFY_TOKEN=

# --- Optional: ATXP / OAuth ---
# Redis URL for storing ATXP OAuth state. Recommended in production.
# OAUTH_DB_REDIS_URL=redis://localhost:6379
# Override authorization server (defaults to https://auth.atxp.ai).
# AUTHORIZATION_SERVER_URL=https://auth.atxp.ai
# Minimum payment per request, USD.
# MINIMUM_PAYMENT=0.01

# --- Optional: app metadata ---
# APP_NAME=usedlocal
# NODE_ENV=development
# LOG_LEVEL=info
# PORT=3001

# --- Optional: analytics ---
# POSTHOG_API_KEY=
