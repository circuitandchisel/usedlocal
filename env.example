# --- Required ---

# Funding destination URL for ATXP payments
FUNDING_DESTINATION_ATXP=https://accounts.atxp.ai/?connection_token=your_connection_token_here

# Redis URL — required. Used for ATXP OAuth state AND the async-search task queue.
OAUTH_DB_REDIS_URL=redis://localhost:6379

# --- Optional: pricing ---
# Per-source underlying cost in USD. Defaults assume realistic backends:
#   craigslist: direct HTTP, effectively free
#   kijiji:     paid scrape backend (Apify / ScraperAPI / Playwright + proxy)
#   facebook:   paid Apify FB Marketplace actor
# The customer-facing price for a search is:
#   max(sum(source_costs) * PRICING_MARGIN_MULTIPLIER, PRICING_MINIMUM_PRICE)
# When you swap a source's backend, override its cost here and the ATXP charge
# will track automatically.
# SOURCE_COST_CRAIGSLIST=0.001
# SOURCE_COST_KIJIJI=0.05
# SOURCE_COST_FACEBOOK=0.20
# PRICING_MARGIN_MULTIPLIER=1.25
# PRICING_MINIMUM_PRICE=0.02

# --- Optional: source toggles ---
# Default sources to query when the client does not specify, comma-separated.
# Defaults to "craigslist,kijiji". Add "facebook" once you've configured a backend.
# ENABLED_SOURCES=craigslist,kijiji

# --- Optional: HTTP behaviour ---
# Per-source timeout (ms). Default 30000.
# SOURCE_TIMEOUT_MS=30000
# Max listings to return per source before deduplication. Default 50.
# MAX_RESULTS_PER_SOURCE=50
# Custom User-Agent for outbound scrapes.
# USER_AGENT=

# --- Optional: Facebook Marketplace ---
# If set, the Facebook source proxies through the Apify FB Marketplace actor.
# Without it, requesting `facebook` as a source returns a non-fatal error.
# FACEBOOK_APIFY_TOKEN=

# --- Optional: worker ---
# Concurrent async tasks the worker will process. Default 3.
# MAX_CONCURRENT_TASKS=3

# --- Optional: ATXP ---
# Override authorization server (defaults to https://auth.atxp.ai).
# AUTHORIZATION_SERVER_URL=https://auth.atxp.ai
# Minimum payment per request, USD.
# MINIMUM_PAYMENT=0.01

# --- Optional: app metadata ---
# APP_NAME=usedlocal
# NODE_ENV=development
# LOG_LEVEL=info
# PORT=3001

# --- Optional: analytics ---
# POSTHOG_API_KEY=
